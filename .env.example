# DAMnation environment configuration
# Copy this file to .env and update values before running.

FLASK_ENV=development
# DB_PATH and THUMBNAIL_DIR are used by host-side tools (dam_index.py, dam.py, etc.)
# They must point to the same physical location as DB_DATA_PATH below.
DB_PATH=~/.dvc_dam/assets.db
THUMBNAIL_DIR=~/.dvc_dam/thumbnails

# PROJECTS_ROOT is used by host-side tools. The Docker container overrides this
# with /projects internally — set the host path here and in DB_DATA_PATH.
PROJECTS_ROOT=/path/to/your/projects/root
GH_ORG=your-github-user-or-org

# Storage provider: aws (default) or backblaze
# DAMnation is opinionated toward S3-compatible storage.
# Backblaze B2 is supported via its S3-compatible API -- no extra dependencies.
STORAGE_PROVIDER=aws

# S3 bucket used by dam_init.py -- one bucket shared across all projects,
# each project gets its own prefix: s3://{DVC_S3_BUCKET}/{project_name}/
DVC_S3_BUCKET=your-damnation-bucket

# Backblaze B2 (set STORAGE_PROVIDER=backblaze and uncomment below)
# Create your bucket manually in the Backblaze console first.
# B2_ENDPOINT_URL format: https://s3.<region>.backblazeb2.com
# B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
# AWS_ACCESS_KEY_ID=your-b2-keyID
# AWS_SECRET_ACCESS_KEY=your-b2-applicationKey
# DVC_REPO_URL_TEMPLATE is a pattern, not a single project URL.
# {org} and {project} are substituted at runtime per-command.
# You never need to change this when adding new projects.
DVC_REPO_URL_TEMPLATE=https://github.com/{org}/{project}.git
GIT_BRANCH=main
GIT_SSH_COMMAND=ssh -o StrictHostKeyChecking=no
AWS_DEFAULT_REGION=us-east-1
WEB_PORT=5000

# Docker volume paths (used by docker-compose only)
# IMPORTANT: Use absolute paths here — Docker Compose does not expand ~ or $HOME.
DB_DATA_PATH=/absolute/path/to/.dvc_dam
SSH_PATH=/absolute/path/to/.ssh
AWS_CREDENTIALS_PATH=/absolute/path/to/.aws
